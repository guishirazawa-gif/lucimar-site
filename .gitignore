.DS_Store
**/.DS_Store

# Heavy original source images (optimized copies live in assets/).
# Leading slash anchors to repo root so assets/photos/ is NOT matched
# (git is case-insensitive on macOS).
/Photos/
/Photos serviços /

# Uncompressed source images dropped directly into assets/ (the optimized
# .jpg versions are what the site actually uses). Kept locally, not deployed.
/assets/storefront.png
/assets/services/*.png

